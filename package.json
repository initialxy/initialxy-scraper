{
  "name": "initialxy-scraper",
  "version": "1.0.2",
  "description": "Minimal browser meant for scripted scraping",
  "license": "MIT",
  "author": "initialxy@gmail.com",
  "type": "module",
  "main": "src/main/main.ts",
  "scripts": {
    "start": "npm run build && electron .",
    "dev": "vite",
    "electron:dev": "electron . --enable-logging",
    "build": "vite build",
    "lint": "eslint src/**/*.ts",
    "lint:fix": "eslint src/**/*.ts --fix",
    "format": "prettier --write src/**/*.ts",
    "format:check": "prettier --check src/**/*.ts",
    "typecheck": "tsc --noEmit",
    "check": "npm run lint && npm run format:check && npm run typecheck",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:main": "vitest run --project=main",
    "test:coverage": "vitest run --coverage",
    "prepare": "husky"
  },
  "dependencies": {
    "commander": "^14.0.3",
    "electron": "^40.6.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@testing-library/dom": "^10.4.1",
    "@types/jsdom": "^28.0.0",
    "@types/node": "^25.3.3",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "@vitest/ui": "^4.1.0",
    "electron-builder": "^26.8.1",
    "eslint": "^10.0.2",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "jsdom": "^29.0.0",
    "prettier": "^3.8.1",
    "typescript": "^5.9.3",
    "vite": "^7.2.4",
    "vitest": "^4.1.0"
  }
}
